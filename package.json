{
  "name": "topstepx-cli",
  "version": "1.0.0",
  "description": "CLI tool for the TopStepX / ProjectX Gateway API",
  "bin": {
    "topstep": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "topstepx",
    "trading",
    "cli",
    "futures"
  ],
  "license": "MIT",
  "dependencies": {
    "@commander-js/extra-typings": "^14.0.0",
    "@inquirer/confirm": "^6.0.8",
    "@inquirer/input": "^5.0.8",
    "@inquirer/password": "^5.0.8",
    "@microsoft/signalr": "^10.0.0",
    "@napi-rs/keyring": "^1.2.0",
    "ansis": "^4.2.0",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
